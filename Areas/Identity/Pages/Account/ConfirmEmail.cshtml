@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm email";
}

<div class="auth-shell">
    <section class="auth-card">
        <p class="page-eyebrow">Email confirmation</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">@(Model.IsSuccess ? "Email confirmed." : "Confirmation issue.")</h1>
        <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">@Model.StatusMessage</p>

        <div class="mt-8 flex flex-wrap gap-3">
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-primary">Log in</a>
            <a asp-page="./ResendEmailConfirmation" class="btn btn-secondary">Resend confirmation</a>
        </div>
    </section>
</div>
