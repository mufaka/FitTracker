@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="auth-shell">
    <section class="auth-card flex flex-col justify-between">
        <div>
            <p class="page-eyebrow">Password reset</p>
            <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">Get back into your account.</h1>
            <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">Enter the email tied to your FitTracker account and a reset link will be prepared for you.</p>
        </div>

        <div class="mt-10 rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Need a quick reset?</p>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Use the same email you registered with and choose a fresh password on the next step.</p>
        </div>
    </section>

    <section class="auth-card">
        <div class="mb-8">
            <p class="page-eyebrow">Recovery</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Request a reset link</h2>
        </div>

        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div>
                <label asp-for="Input.Email" class="input-label"></label>
                <input asp-for="Input.Email" class="input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="mt-2 block text-sm text-red-500"></span>
            </div>

            <button type="submit" class="btn btn-primary w-full justify-center">Send reset link</button>

            <p class="text-sm text-slate-500 dark:text-slate-400">
                Remembered your password?
                <a asp-page="./Login" class="font-medium text-primary-600 dark:text-primary-300">Back to log in</a>
            </p>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
