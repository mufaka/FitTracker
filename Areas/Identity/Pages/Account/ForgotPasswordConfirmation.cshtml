@page
@{
    ViewData["Title"] = "Reset link sent";
    var email = TempData["ResetPasswordEmail"] as string;
    var resetLink = TempData["ResetPasswordLink"] as string;
}

<div class="auth-shell">
    <section class="auth-card">
        <p class="page-eyebrow">Check your email</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">Password reset requested.</h1>
        <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">
            If an account exists for @(string.IsNullOrWhiteSpace(email) ? "the provided email" : email), a password reset link has been generated.
        </p>

        @if (!string.IsNullOrWhiteSpace(resetLink))
        {
            <div class="mt-8 rounded-[1.75rem] border border-primary-200/80 bg-primary-50/80 p-5 dark:border-primary-500/20 dark:bg-primary-500/10">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-600 dark:text-primary-300">Development shortcut</p>
                <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">Email delivery is not configured, so the reset link is shown below for local development.</p>
                <a href="@resetLink" class="btn btn-primary mt-5">Open reset link</a>
            </div>
        }

        <div class="mt-8 flex flex-wrap gap-3">
            <a asp-page="./Login" class="btn btn-primary">Back to log in</a>
            <a asp-page="./ForgotPassword" class="btn btn-secondary">Request another link</a>
        </div>
    </section>
</div>
