@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-shell">
    <section class="auth-card flex flex-col justify-between">
        <div>
            <p class="page-eyebrow">Welcome back</p>
            <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">Log in to continue training.</h1>
            <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">Pick up where you left off, review progress, and keep your workout streak moving.</p>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="metric-card">
                <p class="metric-label">Quick logging</p>
                <p class="metric-value text-primary-600 dark:text-primary-300">Fast</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Workout history</p>
                <p class="metric-value text-violet-600 dark:text-violet-300">Clear</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Daily insights</p>
                <p class="metric-value text-emerald-600 dark:text-emerald-300">Ready</p>
            </div>
        </div>
    </section>

    <section class="auth-card">
        <div class="mb-8">
            <p class="page-eyebrow">Account access</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Use your FitTracker account</h2>
        </div>

        <form id="account" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div>
                <label asp-for="Input.Email" class="input-label"></label>
                <input asp-for="Input.Email" class="input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="mt-2 block text-sm text-red-500"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="input-label"></label>
                <input asp-for="Input.Password" class="input" autocomplete="current-password" aria-required="true" placeholder="Password" />
                <span asp-validation-for="Input.Password" class="mt-2 block text-sm text-red-500"></span>
            </div>

            <label asp-for="Input.RememberMe" class="checkbox-field">
                <input asp-for="Input.RememberMe" />
                <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
            </label>

            <button id="login-submit" type="submit" class="btn btn-primary w-full justify-center">Log in</button>

            <div class="space-y-2 text-sm text-slate-500 dark:text-slate-400">
                <p><a id="forgot-password" asp-page="./ForgotPassword" class="font-medium text-primary-600 dark:text-primary-300">Forgot your password?</a></p>
                <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="font-medium text-primary-600 dark:text-primary-300">Create a new account</a></p>
                <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="font-medium text-primary-600 dark:text-primary-300">Resend email confirmation</a></p>
            </div>
        </form>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="mt-8 border-t border-slate-200 pt-8 dark:border-slate-800">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Use another service</p>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mt-4 flex flex-wrap gap-3">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-secondary" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                    }
                </form>
            </div>
        }
    </section>
</div>

