@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="page-shell">
    <section class="hero-card">
        <div class="page-header gap-8">
            <div>
                <p class="page-eyebrow">Account</p>
                <h1 class="page-title">Profile settings</h1>
                <p class="page-description">Manage the details tied to your FitTracker account.</p>
            </div>
        </div>
    </section>

    <partial name="_StatusMessage" for="StatusMessage" />

    <section class="grid gap-6 xl:grid-cols-[0.7fr_1.3fr]">
        <div class="surface-card">
            <p class="page-eyebrow">Overview</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Account details</h2>
            <p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300">Keep your login details current so security features and future account recovery flows work as expected.</p>
        </div>

        <div class="surface-card">
            <form id="profile-form" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                <div>
                    <label asp-for="Username" class="input-label"></label>
                    <input asp-for="Username" class="input" placeholder="Username" disabled />
                </div>

                <div>
                    <label class="input-label">Email</label>
                    <input value="@Model.Email" class="input" disabled />
                    <div class="mt-2 flex flex-wrap items-center gap-3 text-sm">
                        @if (Model.IsEmailConfirmed)
                        {
                            <span class="chip chip-success">Confirmed</span>
                        }
                        else
                        {
                            <span class="chip">Not confirmed</span>
                            <a asp-area="Identity" asp-page="/Account/ResendEmailConfirmation" asp-route-email="@Model.Email" class="font-medium text-primary-600 dark:text-primary-300">Resend confirmation email</a>
                        }
                    </div>
                </div>

                <div>
                    <label asp-for="Input.PhoneNumber" class="input-label"></label>
                    <input asp-for="Input.PhoneNumber" class="input" placeholder="Please enter your phone number." />
                    <span asp-validation-for="Input.PhoneNumber" class="mt-2 block text-sm text-red-500"></span>
                </div>

                <div>
                    <label asp-for="Input.PreferredUnits" class="input-label"></label>
                    <select asp-for="Input.PreferredUnits" class="input">
                        <option value="lbs">Pounds (lbs)</option>
                        <option value="kg">Kilograms (kg)</option>
                    </select>
                    <span asp-validation-for="Input.PreferredUnits" class="mt-2 block text-sm text-red-500"></span>
                </div>

                <div>
                    <label asp-for="Input.DefaultRestTimer" class="input-label"></label>
                    <input asp-for="Input.DefaultRestTimer" class="input" min="15" step="15" />
                    <span asp-validation-for="Input.DefaultRestTimer" class="mt-2 block text-sm text-red-500"></span>
                </div>

                <div>
                    <label asp-for="Input.Goals" class="input-label"></label>
                    <textarea asp-for="Input.Goals" class="input" rows="4" placeholder="Examples: build strength, improve consistency, train three times per week"></textarea>
                    <span asp-validation-for="Input.Goals" class="mt-2 block text-sm text-red-500"></span>
                </div>

                <button id="update-profile-button" type="submit" class="btn btn-primary">Save changes</button>
            </form>
        </div>
    </section>
</div>

