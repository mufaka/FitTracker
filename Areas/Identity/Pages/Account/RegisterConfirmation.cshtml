@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<div class="auth-shell">
    <section class="auth-card">
        <p class="page-eyebrow">Confirm your email</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">One more step.</h1>
        <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">A confirmation email has been prepared for <span class="font-semibold text-slate-900 dark:text-white">@Model.Email</span>. Use the link in that message to verify your account.</p>

        @if (Model.ShowDevelopmentLink)
        {
            <div class="mt-8 rounded-[1.75rem] border border-primary-200/80 bg-primary-50/80 p-5 dark:border-primary-500/20 dark:bg-primary-500/10">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-600 dark:text-primary-300">Development shortcut</p>
                <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">Email delivery is not configured, so the confirmation link is available below for local development.</p>
                <a href="@Model.EmailConfirmationUrl" class="btn btn-primary mt-5">Confirm email</a>
            </div>
        }

        <div class="mt-8 flex flex-wrap gap-3">
            <form method="post" asp-page-handler="Resend">
                <input type="hidden" name="email" value="@Model.Email" />
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <button type="submit" class="btn btn-secondary">Resend email</button>
            </form>
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-primary">Continue to login</a>
        </div>
    </section>
</div>
