@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="auth-shell">
    <section class="auth-card flex flex-col justify-between">
        <div>
            <p class="page-eyebrow">Choose a new password</p>
            <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">Reset your FitTracker password.</h1>
            <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">Create a fresh password to regain access to your workout history, analytics, and active plans.</p>
        </div>

        <div class="mt-10 rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Password tips</p>
            <ul class="mt-4 space-y-3 text-sm text-slate-600 dark:text-slate-300">
                <li>• Use at least 6 characters</li>
                <li>• Include upper and lower case letters</li>
                <li>• Add a number for a stronger sign-in</li>
            </ul>
        </div>
    </section>

    <section class="auth-card">
        <div class="mb-8">
            <p class="page-eyebrow">New credentials</p>
            <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950 dark:text-white">Set your new password</h2>
        </div>

        <form method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div>
                <label asp-for="Input.Email" class="input-label"></label>
                <input asp-for="Input.Email" class="input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="mt-2 block text-sm text-red-500"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="input-label"></label>
                <input asp-for="Input.Password" class="input" autocomplete="new-password" aria-required="true" placeholder="New password" />
                <span asp-validation-for="Input.Password" class="mt-2 block text-sm text-red-500"></span>
            </div>

            <div>
                <label asp-for="Input.ConfirmPassword" class="input-label"></label>
                <input asp-for="Input.ConfirmPassword" class="input" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" />
                <span asp-validation-for="Input.ConfirmPassword" class="mt-2 block text-sm text-red-500"></span>
            </div>

            <button type="submit" class="btn btn-primary w-full justify-center">Reset password</button>
        </form>
    </section>
</div>

