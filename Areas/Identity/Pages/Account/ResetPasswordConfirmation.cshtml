@page
@{
    ViewData["Title"] = "Password reset complete";
}

<div class="auth-shell">
    <section class="auth-card">
        <p class="page-eyebrow">All set</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white">Your password has been reset.</h1>
        <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-400">You can now sign back in with your updated credentials.</p>

        <div class="mt-8 flex flex-wrap gap-3">
            <a asp-page="./Login" class="btn btn-primary">Log in</a>
            <a asp-page="./ForgotPassword" class="btn btn-secondary">Reset another password</a>
        </div>
    </section>
</div>
