@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = Model.Exercise?.Name ?? "Exercise Details";
}

<div class="page-shell">
    @if (Model.Exercise != null)
    {
        <div>
            <a asp-page="/Exercises/Index" class="chip">← Back to exercise library</a>
        </div>

        <section class="hero-card">
            <div class="page-header gap-8">
                <div>
                    <p class="page-eyebrow">Exercise detail</p>
                    <h1 class="page-title">@Model.Exercise.Name</h1>
                    <p class="page-description">@(!string.IsNullOrWhiteSpace(Model.Exercise.Description) ? Model.Exercise.Description : "Movement details, equipment, and history in one place.")</p>
                    <div class="mt-5 flex flex-wrap gap-2">
                        <span class="chip chip-primary">@Model.Exercise.Category</span>
                        <span class="chip">@Model.Exercise.Equipment</span>
                        @foreach (var muscle in Model.Exercise.MuscleGroups.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                        {
                            <span class="chip">@muscle</span>
                        }
                    </div>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a asp-page="/Workouts/Start" class="btn btn-primary">Add to workout</a>
                    @if (!string.IsNullOrEmpty(Model.Exercise.VideoUrl))
                    {
                        <a href="@Model.Exercise.VideoUrl" target="_blank" rel="noreferrer" class="btn btn-secondary">Watch demo</a>
                    }
                </div>
            </div>
        </section>

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            <div class="metric-card">
                <p class="metric-label">Primary equipment</p>
                <p class="metric-value text-slate-950 dark:text-white">@Model.Exercise.Equipment</p>
                <p class="metric-meta">Movement setup</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Muscle groups</p>
                <p class="metric-value text-primary-600 dark:text-primary-300">@Model.Exercise.MuscleGroups.Split(',', StringSplitOptions.RemoveEmptyEntries).Length</p>
                <p class="metric-meta">Tracked targets</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Category</p>
                <p class="metric-value text-violet-600 dark:text-violet-300">@Model.Exercise.Category</p>
                <p class="metric-meta">Library classification</p>
            </div>
        </section>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <section class="surface-card">
                <div class="mb-6 flex items-start justify-between gap-4">
                    <div>
                        <p class="page-eyebrow">Your history</p>
                        <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Previous performance</h2>
                    </div>
                    <span class="chip">@Model.UsageCount log@(Model.UsageCount == 1 ? string.Empty : "s")</span>
                </div>

                @if (Model.UsageCount > 0)
                {
                    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                        <div class="rounded-[1.5rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Times logged</p>
                            <p class="mt-3 text-3xl font-semibold text-primary-600 dark:text-primary-300">@Model.UsageCount</p>
                        </div>
                        <div class="rounded-[1.5rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Last performed</p>
                            <p class="mt-3 text-xl font-semibold text-slate-950 dark:text-white">@(Model.LastPerformed?.ToString("MMM dd, yyyy") ?? "Not available")</p>
                        </div>
                        <div class="rounded-[1.5rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Best set</p>
                            <p class="mt-3 text-xl font-semibold text-slate-950 dark:text-white">
                                @if (Model.BestSet != null)
                                {
                                    @if (Model.BestSet.Weight.HasValue)
                                    {
                                        <span>@Model.BestSet.Weight.Value.ToString("0.##") lbs</span>
                                        @if (Model.BestSet.Reps.HasValue)
                                        {
                                            <span> × @Model.BestSet.Reps reps</span>
                                        }
                                    }
                                    else if (Model.BestSet.Reps.HasValue)
                                    {
                                        <span>@Model.BestSet.Reps reps</span>
                                    }
                                }
                                else
                                {
                                    <span>No personal best yet</span>
                                }
                            </p>
                        </div>
                    </div>

                    @if (Model.PersonalRecords.Any())
                    {
                        <div class="mt-6 rounded-[1.75rem] border border-amber-200/80 bg-amber-50/80 p-5 dark:border-amber-500/20 dark:bg-amber-500/10">
                            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                                <div>
                                    <p class="page-eyebrow">Personal records</p>
                                    <h3 class="mt-2 text-lg font-semibold text-slate-950 dark:text-white">Your strongest recent efforts</h3>
                                </div>
                                <a asp-page="/PRs/Index" class="btn btn-secondary">View all PRs</a>
                            </div>

                            <div class="mt-4 space-y-3">
                                @foreach (var record in Model.PersonalRecords.Take(5))
                                {
                                    <div class="rounded-[1.25rem] border border-white/70 bg-white/80 px-4 py-3 dark:border-white/10 dark:bg-slate-950/60">
                                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                            <div>
                                                <p class="font-semibold text-slate-950 dark:text-white">@record.Weight.ToString("0.##") lbs × @record.Reps</p>
                                                <p class="text-sm text-slate-500 dark:text-slate-400">@record.Date.ToString("MMM dd, yyyy")</p>
                                            </div>
                                            <span class="chip chip-success">1RM @record.OneRepMax.ToString("0.##")</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <h3 class="text-xl font-semibold text-slate-950 dark:text-white">No history yet</h3>
                        <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">Once you log this exercise, FitTracker will start surfacing your usage and best efforts here.</p>
                    </div>
                }
            </section>
        }
    }
    else
    {
        <div class="empty-state">
            <h3 class="text-xl font-semibold text-slate-950 dark:text-white">Exercise not found</h3>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">The exercise you requested is unavailable.</p>
            <a asp-page="/Exercises/Index" class="btn btn-secondary mt-5">Return to library</a>
        </div>
    }
</div>
