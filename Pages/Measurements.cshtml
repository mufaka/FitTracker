@page
@using System.Text.Json
@model FitTracker.Pages.MeasurementsModel
@{
    ViewData["Title"] = "Measurements";
}

<div class="page-shell">
    <section class="hero-card">
        <div class="page-header gap-8">
            <div>
                <p class="page-eyebrow">Body measurements</p>
                <h1 class="page-title">Track changes beyond the barbell.</h1>
                <p class="page-description">Log body weight, body fat, and key measurements over time so your monthly summaries capture more than workout volume.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a asp-page="/Progress/Index" class="btn btn-secondary">Progress</a>
                <a asp-page="/Analytics/Monthly" class="btn btn-secondary">Monthly summary</a>
                @if (Model.EditId.HasValue)
                {
                    <a asp-page="/Measurements" class="btn btn-primary">Add new entry</a>
                }
            </div>
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
        <div class="metric-card">
            <p class="metric-label">Entries logged</p>
            <p class="metric-value text-primary-600 dark:text-primary-300">@Model.Measurements.Count</p>
            <p class="metric-meta">Saved measurement check-ins</p>
        </div>
        <div class="metric-card">
            <p class="metric-label">Latest weight</p>
            <p class="metric-value text-emerald-600 dark:text-emerald-300">@(Model.LatestWeight?.ToString("0.##") ?? "—")</p>
            <p class="metric-meta">Most recent recorded body weight</p>
        </div>
        <div class="metric-card">
            <p class="metric-label">Latest body fat</p>
            <p class="metric-value text-violet-600 dark:text-violet-300">@(Model.LatestBodyFatPercentage.HasValue ? $"{Model.LatestBodyFatPercentage:0.##}%" : "—")</p>
            <p class="metric-meta">Latest composition update</p>
        </div>
    </section>

    <div class="grid gap-8 xl:grid-cols-[0.95fr_1.05fr]">
        <section class="surface-card">
            <div class="mb-6 flex items-center justify-between gap-4">
                <div>
                    <p class="page-eyebrow">@(Model.EditId.HasValue ? "Edit entry" : "New entry")</p>
                    <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">@(Model.EditId.HasValue ? "Update measurement" : "Add a measurement")</h2>
                </div>
                @if (Model.LatestMeasurementDate.HasValue)
                {
                    <span class="chip">Last update @Model.LatestMeasurementDate.Value.ToString("MMM dd")</span>
                }
            </div>

            <form method="post" asp-page-handler="Save" class="space-y-5">
                <input asp-for="Measurement.Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="rounded-[1.25rem] border border-red-200 bg-red-50/80 px-4 py-3 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200"></div>

                <div>
                    <label asp-for="Measurement.Date" class="input-label"></label>
                    <input asp-for="Measurement.Date" type="date" class="input" />
                    <span asp-validation-for="Measurement.Date" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label asp-for="Measurement.Weight" class="input-label"></label>
                        <input asp-for="Measurement.Weight" type="number" step="0.1" class="input" placeholder="180.0" />
                        <span asp-validation-for="Measurement.Weight" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                    </div>
                    <div>
                        <label asp-for="Measurement.BodyFatPercentage" class="input-label"></label>
                        <input asp-for="Measurement.BodyFatPercentage" type="number" step="0.1" class="input" placeholder="18.5" />
                        <span asp-validation-for="Measurement.BodyFatPercentage" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                    </div>
                    <div>
                        <label asp-for="Measurement.Chest" class="input-label"></label>
                        <input asp-for="Measurement.Chest" type="number" step="0.1" class="input" placeholder="42.0" />
                        <span asp-validation-for="Measurement.Chest" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                    </div>
                    <div>
                        <label asp-for="Measurement.Waist" class="input-label"></label>
                        <input asp-for="Measurement.Waist" type="number" step="0.1" class="input" placeholder="34.0" />
                        <span asp-validation-for="Measurement.Waist" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                    </div>
                    <div>
                        <label asp-for="Measurement.Arms" class="input-label"></label>
                        <input asp-for="Measurement.Arms" type="number" step="0.1" class="input" placeholder="15.5" />
                        <span asp-validation-for="Measurement.Arms" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                    </div>
                    <div>
                        <label asp-for="Measurement.Legs" class="input-label"></label>
                        <input asp-for="Measurement.Legs" type="number" step="0.1" class="input" placeholder="24.0" />
                        <span asp-validation-for="Measurement.Legs" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Measurement.Notes" class="input-label"></label>
                    <textarea asp-for="Measurement.Notes" rows="3" class="input" placeholder="How did you feel, what changed, what stood out?"></textarea>
                    <span asp-validation-for="Measurement.Notes" class="mt-2 block text-sm text-red-600 dark:text-red-300"></span>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="btn btn-primary">@(Model.EditId.HasValue ? "Save changes" : "Add measurement")</button>
                    @if (Model.EditId.HasValue)
                    {
                        <a asp-page="/Measurements" class="btn btn-secondary">Cancel</a>
                    }
                </div>
            </form>
        </section>

        <section class="surface-card">
            <div class="mb-6 flex items-center justify-between gap-4">
                <div>
                    <p class="page-eyebrow">Trend charts</p>
                    <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Progress trends</h2>
                </div>
                <span class="chip">Responsive charts</span>
            </div>

            @if (Model.Measurements.Any(m => m.Weight.HasValue || m.BodyFatPercentage.HasValue || m.Waist.HasValue))
            {
                <div class="space-y-6">
                    <div class="rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-4 dark:border-slate-800 dark:bg-slate-900/70">
                        <canvas id="measurementWeightChart" height="160"></canvas>
                    </div>
                    <div class="rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-4 dark:border-slate-800 dark:bg-slate-900/70">
                        <canvas id="measurementCompositionChart" height="160"></canvas>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3 class="text-xl font-semibold text-slate-950 dark:text-white">No measurement data yet</h3>
                    <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">Add your first body check-in to start charting weight, body fat, and waist trends.</p>
                </div>
            }
        </section>
    </div>

    <section class="surface-card">
        <div class="mb-6 flex items-center justify-between gap-4">
            <div>
                <p class="page-eyebrow">Measurement history</p>
                <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">All check-ins</h2>
            </div>
            <span class="chip">Newest first</span>
        </div>

        @if (Model.Measurements.Any())
        {
            <div class="table-shell">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Weight</th>
                            <th>Body fat</th>
                            <th>Waist</th>
                            <th>Notes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var measurement in Model.Measurements)
                        {
                            <tr>
                                <td class="font-semibold">@measurement.Date.ToString("MMM dd, yyyy")</td>
                                <td>@(measurement.Weight?.ToString("0.##") ?? "—")</td>
                                <td>@(measurement.BodyFatPercentage.HasValue ? $"{measurement.BodyFatPercentage:0.##}%" : "—")</td>
                                <td>@(measurement.Waist?.ToString("0.##") ?? "—")</td>
                                <td class="max-w-xs truncate">@(string.IsNullOrWhiteSpace(measurement.Notes) ? "—" : measurement.Notes)</td>
                                <td>
                                    <div class="flex flex-wrap gap-2">
                                        <a asp-page="/Measurements" asp-route-editId="@measurement.Id" class="btn btn-secondary">Edit</a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@measurement.Id" onsubmit="return confirm('Delete this measurement entry?');">
                                            <button type="submit" class="btn btn-danger">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <h3 class="text-xl font-semibold text-slate-950 dark:text-white">No measurements logged yet</h3>
                <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">Use this page to track body changes alongside your workout history.</p>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
    <script>
        const measurementLabels = @Html.Raw(JsonSerializer.Serialize(Model.Measurements.OrderBy(m => m.Date).Select(m => m.Date.ToString("MMM dd"))));
        const measurementWeights = @Html.Raw(JsonSerializer.Serialize(Model.Measurements.OrderBy(m => m.Date).Select(m => m.Weight)));
        const measurementBodyFat = @Html.Raw(JsonSerializer.Serialize(Model.Measurements.OrderBy(m => m.Date).Select(m => m.BodyFatPercentage)));
        const measurementWaist = @Html.Raw(JsonSerializer.Serialize(Model.Measurements.OrderBy(m => m.Date).Select(m => m.Waist)));

        const isDarkMode = document.documentElement.classList.contains('dark');
        const axisColor = isDarkMode ? '#cbd5e1' : '#475569';
        const gridColor = isDarkMode ? 'rgba(148, 163, 184, 0.18)' : 'rgba(148, 163, 184, 0.25)';

        const sharedOptions = {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    ticks: { color: axisColor },
                    grid: { color: gridColor }
                },
                y: {
                    beginAtZero: false,
                    ticks: { color: axisColor },
                    grid: { color: gridColor }
                }
            },
            plugins: {
                legend: { labels: { color: axisColor } }
            }
        };

        const weightContext = document.getElementById('measurementWeightChart');
        if (weightContext) {
            new Chart(weightContext, {
                type: 'line',
                data: {
                    labels: measurementLabels,
                    datasets: [
                        {
                            label: 'Weight',
                            data: measurementWeights,
                            borderColor: 'rgba(59, 130, 246, 1)',
                            backgroundColor: 'rgba(59, 130, 246, 0.16)',
                            tension: 0.35,
                            fill: true,
                            spanGaps: true
                        }
                    ]
                },
                options: sharedOptions
            });
        }

        const compositionContext = document.getElementById('measurementCompositionChart');
        if (compositionContext) {
            new Chart(compositionContext, {
                type: 'line',
                data: {
                    labels: measurementLabels,
                    datasets: [
                        {
                            label: 'Body fat %',
                            data: measurementBodyFat,
                            borderColor: 'rgba(16, 185, 129, 1)',
                            backgroundColor: 'rgba(16, 185, 129, 0.14)',
                            tension: 0.35,
                            fill: false,
                            spanGaps: true
                        },
                        {
                            label: 'Waist',
                            data: measurementWaist,
                            borderColor: 'rgba(139, 92, 246, 1)',
                            backgroundColor: 'rgba(139, 92, 246, 0.14)',
                            tension: 0.35,
                            fill: false,
                            spanGaps: true
                        }
                    ]
                },
                options: sharedOptions
            });
        }
    </script>
}
