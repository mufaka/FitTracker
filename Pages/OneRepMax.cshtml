@page
@using FitTracker.Services
@model FitTracker.Pages.OneRepMaxModel
@{
    ViewData["Title"] = "1RM Calculator";
}

<div class="page-shell">
    <section class="hero-card">
        <div class="page-header gap-8">
            <div>
                <p class="page-eyebrow">1RM calculator</p>
                <h1 class="page-title">Estimate your one-rep max.</h1>
                <p class="page-description">Compare Epley, Brzycki and Lombardi estimates, then use the blended average as a practical working number for future training.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a asp-page="/Progress/OneRepMax" class="btn btn-secondary">1RM tracking</a>
                <a asp-page="/Progress/Index" class="btn btn-secondary">Progress</a>
                <a asp-page="/Analytics/Index" class="btn btn-secondary">Analytics</a>
            </div>
        </div>
    </section>

    <div class="grid gap-8 xl:grid-cols-[0.9fr_1.1fr]">
        <section class="surface-card">
            <div class="mb-6">
                <p class="page-eyebrow">Inputs</p>
                <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Calculate from a working set</h2>
            </div>

            <form method="get" class="space-y-5">
                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="input-label" asp-for="Weight"></label>
                        <input asp-for="Weight" type="number" step="0.1" class="input" placeholder="185" />
                    </div>
                    <div>
                        <label class="input-label" asp-for="Reps"></label>
                        <input asp-for="Reps" type="number" min="1" class="input" placeholder="5" />
                        <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">@OneRepMaxCalculator.MinimumEstimateReps–@OneRepMaxCalculator.MaximumEstimateReps reps, or 1 for a true max.</p>
                    </div>
                </div>

                <div>
                    <label class="input-label" asp-for="Units">Units</label>
                    <select asp-for="Units" class="input">
                        <option value="lbs">lbs</option>
                        <option value="kg">kg</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Calculate 1RM</button>
            </form>
        </section>

        <section class="surface-card">
            <div class="mb-6 flex items-center justify-between gap-4">
                <div>
                    <p class="page-eyebrow">Estimates</p>
                    <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Formula comparison</h2>
                </div>
                <span class="chip">Use for planning, not testing</span>
            </div>

            @if (Model.Estimate.HasValue)
            {
                <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    <div class="metric-card">
                        <p class="metric-label">Epley</p>
                        <p class="metric-value text-primary-600 dark:text-primary-300">@Model.Estimate.Epley.ToString("0.##")</p>
                        <p class="metric-meta">@UnitConverter.WeightUnitLabel(Model.Units).ToUpperInvariant()</p>
                    </div>
                    <div class="metric-card">
                        <p class="metric-label">Brzycki</p>
                        <p class="metric-value text-emerald-600 dark:text-emerald-300">@Model.Estimate.Brzycki.ToString("0.##")</p>
                        <p class="metric-meta">@UnitConverter.WeightUnitLabel(Model.Units).ToUpperInvariant()</p>
                    </div>
                    <div class="metric-card">
                        <p class="metric-label">Lombardi</p>
                        <p class="metric-value text-sky-600 dark:text-sky-300">@Model.Estimate.Lombardi.ToString("0.##")</p>
                        <p class="metric-meta">@UnitConverter.WeightUnitLabel(Model.Units).ToUpperInvariant()</p>
                    </div>
                    <div class="metric-card">
                        <p class="metric-label">Average</p>
                        <p class="metric-value text-violet-600 dark:text-violet-300">@Model.Estimate.Average.ToString("0.##")</p>
                        <p class="metric-meta">Recommended default estimate</p>
                    </div>
                </div>

                <div class="mt-6 rounded-[1.5rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Interpretation</p>
                    <p class="mt-3 text-slate-700 dark:text-slate-300">Based on @Model.Weight?.ToString("0.##") @UnitConverter.WeightUnitLabel(Model.Units) × @Model.Reps reps, your blended estimated 1RM is <span class="font-semibold text-slate-950 dark:text-white">@Model.Estimate.Average.ToString("0.##") @UnitConverter.WeightUnitLabel(Model.Units)</span>.</p>
                </div>
            }
            else if (Model.IsOutOfRange)
            {
                <div class="empty-state">
                    <h3 class="text-xl font-semibold text-slate-950 dark:text-white">That set can't be estimated from</h3>
                    <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">
                        The formulas are only fitted for @OneRepMaxCalculator.MinimumEstimateReps–@OneRepMaxCalculator.MaximumEstimateReps reps.
                        A single counts at face value; beyond @OneRepMaxCalculator.MaximumEstimateReps reps the result drifts too far from a real max to be worth acting on.
                        Enter a weight above zero and a rep count in that range.
                    </p>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <h3 class="text-xl font-semibold text-slate-950 dark:text-white">Enter a weight and rep count</h3>
                    <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">Once you provide a working set, FitTracker will calculate Epley, Brzycki, Lombardi, and average 1RM estimates.</p>
                </div>
            }
        </section>
    </div>
</div>
