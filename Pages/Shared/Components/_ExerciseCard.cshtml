@model FitTracker.Models.Exercise

<a asp-page="/Exercises/Details" asp-route-id="@Model.Id" class="surface-card block h-full transition hover:-translate-y-1 hover:border-primary-200 hover:shadow-xl dark:hover:border-primary-500/30">
    <div class="flex h-full flex-col">
        <div class="flex items-start justify-between gap-4">
            <div>
                <div class="flex flex-wrap gap-2">
                    <span class="chip chip-primary">@Model.Category</span>
                    <span class="chip">@Model.Equipment</span>
                </div>
                <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-950 dark:text-white">@Model.Name</h3>
            </div>
            @if (!string.IsNullOrEmpty(Model.VideoUrl))
            {
                <span class="chip">Video</span>
            }
        </div>

        <p class="mt-4 text-sm text-slate-600 dark:text-slate-300">@Model.MuscleGroups</p>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="mt-4 text-sm leading-6 text-slate-500 dark:text-slate-400">@Model.Description</p>
        }

        <div class="mt-auto pt-6">
            <span class="text-sm font-semibold text-primary-600 dark:text-primary-300">View details →</span>
        </div>
    </div>
</a>
