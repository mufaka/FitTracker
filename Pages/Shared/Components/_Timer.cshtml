@model TimerComponentModel

<section class="surface-card" x-cloak data-default-rest-timer-seconds="@Model.DefaultRestTimerSeconds">
    <div class="flex flex-col gap-6 xl:flex-row xl:items-center xl:justify-between">
        <div>
            <p class="page-eyebrow">Rest timer</p>
            <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Recover between sets</h2>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">The timer starts automatically when you add a set and continues even after the page refreshes.</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-[minmax(0,10rem)_auto_auto_auto] sm:items-end">
            <div>
                <label class="input-label" for="restDuration">Duration (seconds)</label>
                <input id="restDuration"
                       type="number"
                       min="15"
                       step="15"
                       class="input"
                       x-model.number="durationSeconds"
                       x-on:change="updateDuration()" />
            </div>
            <button type="button" class="btn btn-secondary" x-on:click="startTimer()" x-text="isRunning ? 'Restart timer' : 'Start timer'"></button>
            <button type="button" class="btn btn-secondary" x-on:click="togglePause()" x-bind:disabled="!hasTimer" x-bind:class="!hasTimer ? 'opacity-50 cursor-not-allowed' : ''" x-text="isRunning ? 'Pause' : 'Resume'"></button>
            <button type="button" class="btn btn-secondary" x-on:click="resetTimer()" x-bind:disabled="!hasTimer && !completed" x-bind:class="!hasTimer && !completed ? 'opacity-50 cursor-not-allowed' : ''">Reset</button>
        </div>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,12rem)] lg:items-center">
        <div>
            <div class="flex items-center justify-between text-sm font-medium text-slate-500 dark:text-slate-400">
                <span x-text="statusText"></span>
                <span x-text="progressLabel"></span>
            </div>
            <div class="mt-3 h-3 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800">
                <div class="h-full rounded-full bg-primary-500 transition-all duration-500"
                     x-bind:style="`width: ${progressPercentage}%`"></div>
            </div>
        </div>

        <div class="rounded-[1.75rem] border border-primary-200/80 bg-primary-50/80 px-5 py-4 text-center dark:border-primary-500/20 dark:bg-primary-500/10">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary-600 dark:text-primary-300">Time remaining</p>
            <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 dark:text-white" x-text="formattedTime"></p>
        </div>
    </div>

    <div class="mt-5 flex flex-wrap gap-3">
        <button type="button" class="chip" x-on:click="setPreset(60)">60 sec</button>
        <button type="button" class="chip" x-on:click="setPreset(90)">90 sec</button>
        <button type="button" class="chip" x-on:click="setPreset(120)">120 sec</button>
        <span class="chip" title="Default rest timer">Default @Model.DefaultRestTimerSeconds sec</span>
        <span class="chip chip-success" x-show="completed" x-cloak>Rest complete</span>
    </div>
</section>
