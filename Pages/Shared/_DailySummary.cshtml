@model FitTracker.Services.DailySummary

@if (Model.WorkoutCount > 0)
{
    <section class="surface-card">
        <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <p class="page-eyebrow">Summary</p>
                <h2 class="text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">Today's totals</h2>
            </div>
            <span class="chip">@Model.Date.ToString("MMM dd")</span>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <div class="metric-card">
                <p class="metric-label">Workouts</p>
                <p class="metric-value text-primary-600 dark:text-primary-300">@Model.WorkoutCount</p>
                <p class="metric-meta">Tracked today</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Total volume</p>
                <p class="metric-value text-emerald-600 dark:text-emerald-300">@Model.TotalVolume.ToString("N0")</p>
                <p class="metric-meta">Pounds moved</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Duration</p>
                <p class="metric-value text-violet-600 dark:text-violet-300">@Model.TotalDuration</p>
                <p class="metric-meta">Minutes logged</p>
            </div>
            <div class="metric-card">
                <p class="metric-label">Calories</p>
                <p class="metric-value text-amber-600 dark:text-amber-300">~@Model.CaloriesBurned</p>
                <p class="metric-meta">Estimated burn</p>
            </div>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total sets</p>
                <p class="mt-3 text-2xl font-semibold text-slate-950 dark:text-white">@Model.TotalSets</p>
            </div>
            <div class="rounded-[1.75rem] border border-slate-200/80 bg-white/70 p-5 dark:border-slate-800 dark:bg-slate-900/70">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Total reps</p>
                <p class="mt-3 text-2xl font-semibold text-slate-950 dark:text-white">@Model.TotalReps</p>
            </div>
        </div>

        @if (Model.ExercisesCompleted.Any())
        {
            <div class="mt-6">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Exercises completed</p>
                <div class="mt-3 flex flex-wrap gap-2">
                    @foreach (var exercise in Model.ExercisesCompleted)
                    {
                        <span class="chip">@exercise</span>
                    }
                </div>
            </div>
        }
    </section>
}
else
{
    <div class="empty-state">
        <svg class="mb-4 h-14 w-14 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
        </svg>
        <h3 class="text-xl font-semibold text-slate-950 dark:text-white">No workouts for this day</h3>
        <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">Once you complete a session, today's totals and exercise summary will appear here.</p>
    </div>
}
