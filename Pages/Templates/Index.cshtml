@page
@model FitTracker.Pages.Templates.IndexModel
@{
    ViewData["Title"] = "Workout Templates";
}

<div class="page-shell">
    <section class="hero-card">
        <div class="page-header gap-8">
            <div>
                <p class="page-eyebrow">Workout templates</p>
                <h1 class="page-title">Build repeatable sessions.</h1>
                <p class="page-description">Create reusable training lineups, tune default set targets, and launch a workout from a saved structure in one click.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a asp-page="/Templates/Create" class="btn btn-primary">Create template</a>
                <a asp-page="/Workouts/Start" class="btn btn-secondary">Start empty workout</a>
            </div>
        </div>
    </section>

    @if (Model.Templates.Any())
    {
        <div class="grid gap-6 xl:grid-cols-2">
            @foreach (var template in Model.Templates)
            {
                var orderedExercises = template.Exercises.OrderBy(te => te.Order).ToList();
                <section class="surface-card">
                    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
                        <div>
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="chip @(template.IsActive ? "chip-success" : string.Empty)">@(template.IsActive ? "Active" : "Paused")</span>
                                <span class="chip">@orderedExercises.Count exercise@(orderedExercises.Count == 1 ? string.Empty : "s")</span>
                            </div>
                            <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">@template.Name</h2>
                            @if (!string.IsNullOrWhiteSpace(template.Description))
                            {
                                <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">@template.Description</p>
                            }
                        </div>
                        <div class="flex flex-wrap gap-3">
                            @if (template.IsActive)
                            {
                                <a asp-page="/Workouts/Start" asp-route-templateId="@template.Id" class="btn btn-primary">Start</a>
                            }
                            <a asp-page="/Templates/Create" asp-route-id="@template.Id" class="btn btn-secondary">Edit</a>
                        </div>
                    </div>

                    <div class="mt-6 space-y-3">
                        @foreach (var exercise in orderedExercises.Take(4))
                        {
                            <div class="rounded-[1.25rem] border border-slate-200/80 bg-white/70 px-4 py-3 dark:border-slate-800 dark:bg-slate-900/70">
                                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                                    <div>
                                        <p class="font-semibold text-slate-950 dark:text-white">@exercise.Order. @exercise.Exercise.Name</p>
                                        <p class="text-sm text-slate-500 dark:text-slate-400">@exercise.Exercise.MuscleGroups · @exercise.Exercise.Equipment</p>
                                    </div>
                                    <span class="chip">@exercise.DefaultSets × @exercise.DefaultReps</span>
                                </div>
                            </div>
                        }

                        @if (orderedExercises.Count > 4)
                        {
                            <p class="text-sm text-slate-500 dark:text-slate-400">+ @(orderedExercises.Count - 4) more exercise@(orderedExercises.Count - 4 == 1 ? string.Empty : "s")</p>
                        }
                    </div>

                    <form method="post" asp-page-handler="Delete" asp-route-id="@template.Id" class="mt-6">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this template?')">Delete template</button>
                    </form>
                </section>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <svg class="mb-4 h-14 w-14 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
            <h2 class="text-xl font-semibold text-slate-950 dark:text-white">No templates yet</h2>
            <p class="mt-2 max-w-md text-sm text-slate-500 dark:text-slate-400">Save your go-to split once, then start future sessions with the same structure in seconds.</p>
            <a asp-page="/Templates/Create" class="btn btn-primary mt-5">Create your first template</a>
        </div>
    }
</div>
