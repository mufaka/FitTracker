@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = $"Workout - {Model.Workout?.Date.ToString("MMM dd, yyyy")}";
}

<div class="page-shell">
    @if (Model.Workout != null)
    {
        <div>
            <a asp-page="/Workouts/History" class="chip">← Back to history</a>
        </div>

        <section class="hero-card">
            <div class="page-header gap-8">
                <div>
                    <p class="page-eyebrow">Workout detail</p>
                    <h1 class="page-title">@Model.Workout.Date.ToString("dddd, MMMM dd, yyyy")</h1>
                    <p class="page-description">Dive into the full session breakdown, from total volume to each logged set.</p>
                    <div class="mt-5 flex flex-wrap gap-2">
                        <span class="chip chip-primary">@Model.Workout.Duration min</span>
                        <span class="chip">@Model.Workout.WorkoutExercises.Count exercises</span>
                        <span class="chip">@Model.TotalSets sets</span>
                    </div>
                </div>
                <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Are you sure you want to delete this workout?')">
                    <button type="submit" class="btn btn-danger">Delete workout</button>
                </form>
            </div>
        </section>

        @if (!string.IsNullOrEmpty(Model.Workout.Notes))
        {
            <section class="surface-card">
                <p class="page-eyebrow">Notes</p>
                <h2 class="mt-2 text-xl font-semibold text-slate-950 dark:text-white">Workout reflection</h2>
                <p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300">@Model.Workout.Notes</p>
            </section>
        }

        @if (Model.TotalVolume > 0)
        {
            <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <div class="metric-card">
                    <p class="metric-label">Total volume</p>
                    <p class="metric-value text-primary-600 dark:text-primary-300">@Model.TotalVolume.ToString("N0")</p>
                    <p class="metric-meta">Pounds moved</p>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Total sets</p>
                    <p class="metric-value text-slate-950 dark:text-white">@Model.TotalSets</p>
                    <p class="metric-meta">Logged efforts</p>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Total reps</p>
                    <p class="metric-value text-violet-600 dark:text-violet-300">@Model.TotalReps</p>
                    <p class="metric-meta">Completed reps</p>
                </div>
                <div class="metric-card">
                    <p class="metric-label">Average RPE</p>
                    <p class="metric-value text-amber-600 dark:text-amber-300">@Model.AverageRPE.ToString("F1")</p>
                    <p class="metric-meta">Intensity marker</p>
                </div>
            </section>
        }

        <section class="space-y-6">
            @foreach (var workoutExercise in Model.Workout.WorkoutExercises.OrderBy(we => we.Order))
            {
                <div class="surface-card">
                    <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div>
                            <div class="flex flex-wrap gap-2">
                                <span class="chip chip-primary">@workoutExercise.Exercise.Equipment</span>
                                <span class="chip">@workoutExercise.Sets.Count set@(workoutExercise.Sets.Count == 1 ? string.Empty : "s")</span>
                            </div>
                            <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950 dark:text-white">@workoutExercise.Exercise.Name</h2>
                            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">@workoutExercise.Exercise.MuscleGroups</p>
                        </div>
                    </div>

                    @if (workoutExercise.Sets.Any())
                    {
                        <div class="table-shell">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Set</th>
                                        <th>Weight</th>
                                        <th>Reps</th>
                                        <th>Volume</th>
                                        <th>RPE</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var set in workoutExercise.Sets.OrderBy(s => s.SetNumber))
                                    {
                                        var volume = (set.Weight ?? 0) * (set.Reps ?? 0);
                                        <tr>
                                            <td class="font-semibold">@set.SetNumber</td>
                                            <td>@(set.Weight?.ToString("F1") ?? "-") lbs</td>
                                            <td>@(set.Reps?.ToString() ?? "-")</td>
                                            <td>@volume.ToString("F0") lbs</td>
                                            <td>@(set.RPE?.ToString() ?? "-")</td>
                                        </tr>
                                    }
                                    <tr class="bg-slate-100/70 font-semibold dark:bg-slate-900/70">
                                        <td colspan="2">Totals</td>
                                        <td>@workoutExercise.Sets.Sum(s => s.Reps ?? 0)</td>
                                        <td>@workoutExercise.Sets.Sum(s => (s.Weight ?? 0) * (s.Reps ?? 0)).ToString("F0") lbs</td>
                                        <td>-</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(workoutExercise.Notes))
                    {
                        <div class="mt-5 rounded-[1.5rem] border border-slate-200/80 bg-white/70 p-4 text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-300">
                            <span class="font-semibold text-slate-950 dark:text-white">Note:</span> @workoutExercise.Notes
                        </div>
                    }
                </div>
            }
        </section>

        <div class="flex flex-wrap gap-3">
            <a asp-page="/Workouts/Start" class="btn btn-primary">Start new workout</a>
            <a asp-page="/Workouts/History" class="btn btn-secondary">Back to history</a>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h3 class="text-xl font-semibold text-slate-950 dark:text-white">Workout not found</h3>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">The session you requested is unavailable.</p>
            <a asp-page="/Workouts/History" class="btn btn-secondary mt-5">Return to history</a>
        </div>
    }
</div>
