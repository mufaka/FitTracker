@page
@model StartModel
@{
    ViewData["Title"] = "Start Workout";

    var workout = Model.Workout;
    var isEditable = workout != null && !workout.IsCompleted;
    var total = Model.WorkoutExercises.Count;
}

<div class="page-shell" x-data="workoutTracker(@(Model.WorkoutId ?? 0), @Model.DefaultRestTimerSeconds)">
    <section class="hero-card">
        <div class="page-header gap-8">
            <div>
                <p class="page-eyebrow">Workout logging</p>
                <h1 class="page-title">@(workout != null ? "Continue your session" : "Start a new workout")</h1>
                <p class="page-description">@DateTime.Now.ToString("dddd, MMMM dd, yyyy") · Add exercises, log sets quickly, and finish with a clean summary.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                @* One exercise at a time is the default — a workout is performed on a phone. The
                   lineup is for building and reviewing, and stays one tap away. *@
                @if (isEditable && total > 0)
                {
                    @if (Model.FocusMode)
                    {
                        <a asp-page="/Workouts/Start" asp-route-id="@Model.WorkoutId" asp-route-list="true" class="btn btn-secondary">Show full list</a>
                    }
                    else
                    {
                        <a asp-page="/Workouts/Start" asp-route-id="@Model.WorkoutId" class="btn btn-primary">Focus mode</a>
                    }
                }
                <a asp-page="/Exercises/Index" class="btn btn-secondary">Browse exercises</a>
                <a asp-page="/Workouts/History" class="btn btn-secondary">Workout history</a>
            </div>
        </div>
    </section>

    @if (isEditable || workout == null)
    {
        <partial name="~/Pages/Shared/Components/_Timer.cshtml"
                 model="new FitTracker.Models.TimerComponentModel { DefaultRestTimerSeconds = Model.DefaultRestTimerSeconds }" />
    }

    <partial name="_WorkoutForm" model="Model" />
</div>

<script>
function workoutTracker(workoutId, defaultRestTimerSeconds) {
    return {
        workoutId,
        defaultRestTimerSeconds,
        durationSeconds: defaultRestTimerSeconds,
        remainingSeconds: defaultRestTimerSeconds,
        endTime: null,
        intervalId: null,
        isRunning: false,
        completed: false,
        autosaveState: null,
        get storageKey() {
            return `fittracker:rest-timer:${this.workoutId}`;
        },
        get autosaveKey() {
            return `fittracker:workout-draft:${this.workoutId}`;
        },
        get hasTimer() {
            return this.remainingSeconds > 0;
        },
        get formattedTime() {
            const minutes = Math.floor(this.remainingSeconds / 60);
            const seconds = this.remainingSeconds % 60;
            return `${minutes}:${seconds.toString().padStart(2, '0')}`;
        },
        get progressPercentage() {
            if (this.durationSeconds <= 0) {
                return 0;
            }

            return Math.max(0, Math.min(100, (this.remainingSeconds / this.durationSeconds) * 100));
        },
        get progressLabel() {
            return `${this.remainingSeconds}s left`;
        },
        get statusText() {
            if (this.completed) {
                return 'Ready for the next set';
            }

            if (this.isRunning) {
                return 'Resting';
            }

            return 'Timer paused';
        },
        init() {
            this.autosaveState = this.loadAutosaveState();
            const savedState = this.loadState();

            // Rehydrate persisted timer state so refreshes do not interrupt an active rest period.
            if (!savedState) {
                this.remainingSeconds = this.durationSeconds;
                return;
            }

            this.durationSeconds = savedState.durationSeconds > 0 ? savedState.durationSeconds : this.defaultRestTimerSeconds;

            if (savedState.endTime) {
                this.endTime = savedState.endTime;
                this.completed = false;
                this.tick();

                if (this.remainingSeconds > 0) {
                    this.isRunning = true;
                    this.startInterval();
                }
            } else {
                this.remainingSeconds = savedState.remainingSeconds > 0 ? savedState.remainingSeconds : this.durationSeconds;
                this.completed = !!savedState.completed;
            }
        },
        setPreset(seconds) {
            this.durationSeconds = seconds;
            this.updateDuration();
        },
        updateDuration() {
            if (!this.durationSeconds || this.durationSeconds < 15) {
                this.durationSeconds = 15;
            }

            if (!this.isRunning) {
                this.remainingSeconds = this.durationSeconds;
                this.completed = false;
                this.saveState();
            }
        },
        startTimer() {
            this.completed = false;
            this.endTime = Date.now() + (this.durationSeconds * 1000);
            this.isRunning = true;
            this.tick();
            this.startInterval();
            this.saveState();
        },
        togglePause() {
            if (this.completed) {
                this.startTimer();
                return;
            }

            if (this.isRunning) {
                this.tick();
                this.stopInterval();
                this.endTime = null;
                this.isRunning = false;
                this.saveState();
                return;
            }

            if (this.remainingSeconds <= 0) {
                this.remainingSeconds = this.durationSeconds;
            }

            this.endTime = Date.now() + (this.remainingSeconds * 1000);
            this.isRunning = true;
            this.startInterval();
            this.saveState();
        },
        resetTimer() {
            this.stopInterval();
            this.isRunning = false;
            this.completed = false;
            this.endTime = null;
            this.remainingSeconds = this.durationSeconds;
            this.saveState();
        },
        startInterval() {
            this.stopInterval();
            this.intervalId = window.setInterval(() => this.tick(), 1000);
        },
        stopInterval() {
            if (this.intervalId) {
                window.clearInterval(this.intervalId);
                this.intervalId = null;
            }
        },
        tick() {
            if (!this.endTime) {
                return;
            }

            const secondsLeft = Math.max(0, Math.ceil((this.endTime - Date.now()) / 1000));
            this.remainingSeconds = secondsLeft;

            if (secondsLeft === 0) {
                this.finishTimer();
            }
        },
        finishTimer() {
            this.stopInterval();
            this.isRunning = false;
            this.completed = true;
            this.endTime = null;
            this.remainingSeconds = 0;

            if ('vibrate' in navigator) {
                navigator.vibrate([120, 80, 120]);
            }

            this.saveState();
        },
        loadState() {
            const raw = localStorage.getItem(this.storageKey);
            if (!raw) {
                return null;
            }

            try {
                return JSON.parse(raw);
            } catch {
                localStorage.removeItem(this.storageKey);
                return null;
            }
        },
        saveState() {
            localStorage.setItem(this.storageKey, JSON.stringify({
                durationSeconds: this.durationSeconds,
                remainingSeconds: this.remainingSeconds,
                endTime: this.endTime,
                completed: this.completed
            }));
        },
        loadAutosaveState() {
            const raw = localStorage.getItem(this.autosaveKey);
            if (!raw) {
                return { selectedExerciseId: '', workoutNotes: '', fields: {} };
            }

            try {
                const parsed = JSON.parse(raw);
                return {
                    selectedExerciseId: parsed.selectedExerciseId ?? '',
                    workoutNotes: parsed.workoutNotes ?? '',
                    fields: parsed.fields ?? {}
                };
            } catch {
                localStorage.removeItem(this.autosaveKey);
                return { selectedExerciseId: '', workoutNotes: '', fields: {} };
            }
        },
        persistAutosaveState() {
            localStorage.setItem(this.autosaveKey, JSON.stringify(this.autosaveState));
        },
        restoreElementValue(element) {
            if (!this.autosaveState) {
                this.autosaveState = this.loadAutosaveState();
            }

            let value = '';

            if (element.name === 'SelectedExerciseId') {
                value = this.autosaveState.selectedExerciseId;
            } else if (element.name === 'WorkoutNotes') {
                value = this.autosaveState.workoutNotes;
            } else {
                value = this.autosaveState.fields[element.name] ?? '';
            }

            if (value !== '' && element.value === '') {
                element.value = value;
            }
        },
        saveElementValue(element) {
            if (!this.autosaveState) {
                this.autosaveState = this.loadAutosaveState();
            }

            // Track shared fields separately from per-exercise inputs so draft restoration works
            // across dynamic workout forms.
            const value = element.value ?? '';

            if (element.name === 'SelectedExerciseId') {
                this.autosaveState.selectedExerciseId = value;
            } else if (element.name === 'WorkoutNotes') {
                this.autosaveState.workoutNotes = value;
            } else if (value === '') {
                delete this.autosaveState.fields[element.name];
            } else {
                this.autosaveState.fields[element.name] = value;
            }

            this.persistAutosaveState();
        },
        clearSetRow(button) {
            // A prescribed row arrives with the plan's target already in it, so declining one has to
            // be a single tap — otherwise the prescription quietly records sets nobody did.
            const row = button.closest('[data-set-row]');
            if (!row) {
                return;
            }

            row.querySelectorAll('input').forEach(input => {
                input.value = '';
                this.saveElementValue(input);
            });
        },
        clearWorkoutState() {
            localStorage.removeItem(this.storageKey);
            localStorage.removeItem(this.autosaveKey);
        }
    }
}
</script>