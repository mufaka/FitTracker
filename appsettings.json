{
  "ConnectionStrings": {
    // Relative paths resolve against the process working directory. Under
    // systemd set WorkingDirectory=, or use an absolute path here.
    "DefaultConnection": "Data Source=FitTracker.db"
  },
  "Storage": {
    // Absolute, or relative to the content root. Either separator works.
    "ProgressPhotosPath": "App_Data/ProgressPhotos"
  },
  "ForwardedHeaders": {
    // IP addresses of TLS-terminating reverse proxies whose X-Forwarded-Proto
    // and X-Forwarded-For headers are trusted. Empty leaves the middleware out,
    // which is right for development and for any deployment reached directly;
    // a deployment behind a proxy sets it per environment. Anything not
    // parseable as an IP fails startup rather than silently going untrusted.
    "KnownProxies": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
