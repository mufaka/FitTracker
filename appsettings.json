{
  "ConnectionStrings": {
    // Relative paths resolve against the process working directory. Under
    // systemd set WorkingDirectory=, or use an absolute path here.
    "DefaultConnection": "Data Source=FitTracker.db"
  },
  "Storage": {
    // Absolute, or relative to the content root. Either separator works.
    "ProgressPhotosPath": "App_Data/ProgressPhotos"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
